# SaaradhiGO Server Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=8000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/saaradhigo

# Security
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars

# Google Maps (for backend distance/route calculation)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Twilio SMS OTP ─────────────────────────────────────────────────────────
# Get these from https://console.twilio.com
# Leave empty to use dev mode (OTP printed in console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Example: TWILIO_PHONE_NUMBER=+12025551234
